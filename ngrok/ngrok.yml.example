# Plantilla ngrok — PC servidor TI (Órdenes de venta + Olnatura Excel)
# No subir con authtoken real. Instalar con: ..\instalar-ngrok-coexistencia.ps1
#
# Arrancar: ngrok start dynamics olnatura
#   dynamics -> Java Spring Boot  localhost:8080  (prueba_ov)
#   olnatura -> FastAPI login      localhost:8011  (Excel_Restringido-)

version: 3

agent:
  authtoken: PEGAR_TOKEN_NGROK_AQUI

tunnels:
  dynamics:
    addr: 8080
    proto: http
  olnatura:
    addr: 8011
    proto: http
